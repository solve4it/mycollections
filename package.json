{
  "name": "mycollections",
  "private": true,
  "description": "A personal collection management application with a plugin architecture",
  "author": "Solve4It <https://solve4it.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/solve4it/mycollections.git"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "spellcheck": "cspell \"**\"",
    "check": "biome check . && cspell \"**\" && turbo run typecheck test build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "cspell": "^9.7.0",
    "turbo": "^2",
    "typescript": "^6",
    "vitest": "^4"
  }
}
