{
  "name": "mycollections",
  "private": true,
  "description": "A personal collection management application with a plugin architecture",
  "author": "Solve4It <https://solve4it.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/solve4it/mycollections.git"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "spellcheck": "cspell \"**\"",
    "check": "biome check . && cspell \"**\" && turbo run typecheck test build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched",
    "*.{js,jsx,ts,tsx,json,md,css,html}": "cspell --no-must-find-files"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "cspell": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "version": "0.0.1"
}
